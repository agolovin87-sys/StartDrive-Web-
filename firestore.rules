// Правила Firestore для StartDrive.
// Развернуть: firebase deploy --only firestore
// Или скопировать содержимое в Firebase Console → Firestore Database → Rules.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Пользователи: чтение — любой авторизованный (для списков по роли в админке/чате).
    // Создание — только свой документ при регистрации.
    // Обновление/удаление — свой документ, администратор или инструктор (для своих курсантов — баланс при оценке).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.id == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.id == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor'
                && userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedCadets', [])));
      match /balance_history/{entryId} {
        allow read, write: if request.auth != null
          && (userId == request.auth.uid
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
              || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor'
                  && userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedCadets', [])));
      }
    }

    match /driving_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    match /instructor_open_windows/{windowId} {
      allow read, write: if request.auth != null;
    }

    // Учебные группы курсантов: чтение — всем авторизованным; создание/изменение — только админ.
    // События для админки (FCM + веб): только чтение админом, запись — из Cloud Functions (Admin SDK).
    match /admin_events/{eventId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
      allow create, update, delete: if false;
    }

    match /cadet_groups/{groupId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // Групповые чаты (Firestore).
    // Чтение: только если uid в memberIds (совместимо с запросом where memberIds array-contains uid).
    // Важно: не использовать is list / hasAny — иначе часть клиентов/данных даёт ложный отказ.
    // Админ: сначала exists(users/{uid}), затем role — без exists get() даёт permission-denied.
    function isChatGroupAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    match /chat_groups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.get('memberIds', []);
      allow create: if isChatGroupAdmin()
        && request.auth.uid in request.resource.data.get('memberIds', []);
      allow update, delete: if isChatGroupAdmin();
    }
  }
}
