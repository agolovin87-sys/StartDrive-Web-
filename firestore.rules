// Правила Firestore для StartDrive.
// Развернуть: firebase deploy --only firestore
// Или скопировать содержимое в Firebase Console → Firestore Database → Rules.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Пользователи: чтение — любой авторизованный (для списков по роли в админке/чате).
    // Создание — только свой документ при регистрации.
    // Обновление/удаление — свой документ, администратор или инструктор (для своих курсантов — баланс при оценке).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.id == request.auth.uid;
      allow update, delete: if request.auth != null
        && (resource.id == request.auth.uid
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
            || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor'
                && userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedCadets', [])));
      match /balance_history/{entryId} {
        allow read, write: if request.auth != null
          && (userId == request.auth.uid
              || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
              || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor'
                  && userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedCadets', [])));
      }
    }

    match /driving_sessions/{sessionId} {
      allow read, write: if request.auth != null;
    }

    match /instructor_open_windows/{windowId} {
      allow read, write: if request.auth != null;
    }
  }
}
